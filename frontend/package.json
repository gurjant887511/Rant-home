    "react-helmet-async": "^3.0.0",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.12.0",
    "react-scripts": "5.0.1",
    "tailwindcss": "^4.2.4"
  },
  "scripts": {
    "start": "cross-env PORT=8001 react-scripts start",
    "dev": "cross-env PORT=8001 react-scripts start",
